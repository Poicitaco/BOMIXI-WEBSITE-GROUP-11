@model ShopLaptop_v1.Models.WarrantyCertificate?
@{
    ViewData["Title"] = "Verify Warranty";
}

<div class="max-w-[900px] mx-auto px-8 py-12">
    <div class="bg-[#0D0D0D] border border-[#1A1A1A] rounded-3xl p-8">
        <h1 class="font-['Space_Grotesk'] text-3xl font-black text-white mb-6">Tra cứu Digital Warranty</h1>
        <form method="get" class="flex gap-3 mb-8">
            <input name="code" value="@Context.Request.Query["code"]" placeholder="Nhập Certificate Code hoặc Token ID"
                   class="flex-1 bg-black border border-[#252525] rounded-xl px-4 py-3 text-white text-sm" />
            <button class="bg-accent-cyber-lime text-black px-6 py-3 rounded-xl font-bold">Tra cứu</button>
        </form>

        @if (Model == null)
        {
            <p class="text-gray-500">Chưa có chứng nhận phù hợp.</p>
        }
        else
        {
            <div class="border border-accent-cyber-lime/30 bg-accent-cyber-lime/5 rounded-2xl p-6">
                <p class="text-accent-cyber-lime text-xs uppercase tracking-[0.3em] font-bold mb-2">Verified Certificate</p>
                <h2 class="font-['Space_Grotesk'] text-2xl font-bold text-white mb-3">@Model.ProductName</h2>
                <p class="text-gray-400 mb-4">@Model.VariantSnapshot</p>
                <div class="space-y-2 text-sm text-gray-300 font-mono">
                    <p>Certificate: @Model.CertificateCode</p>
                    <p>Token: @Model.TokenId</p>
                    <p>Wallet: @(Model.WalletAddress ?? "Chưa liên kết ví")</p>
                    <p>Tx Hash: <span class="text-accent-cyber-lime break-all">@Model.BlockchainTxHash</span></p>
                    <p>Issued: @Model.IssuedAt.ToString("dd/MM/yyyy")</p>
                    <p>Expires: @Model.ExpiresAt.ToString("dd/MM/yyyy")</p>
                </div>
            </div>
        }
    </div>
</div>
