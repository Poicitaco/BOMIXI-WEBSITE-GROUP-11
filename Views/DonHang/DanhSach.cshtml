@model List<ShopLaptop_v1.Models.Order>
@{
    ViewData["Title"] = "Quản lý Đơn hàng";
    string FormatTien(decimal so) => so.ToString("N0") + " VNĐ";
    string MauTrangThai(string s) => s switch {
        "ChoXacNhan" => "bg-yellow-500/10 text-yellow-500 border-yellow-500/30 shadow-[0_0_10px_rgba(234,179,8,0.2)]",
        "DangXuLy"   => "bg-blue-500/10 text-blue-400 border-blue-500/30 shadow-[0_0_10px_rgba(59,130,246,0.2)]",
        "DangGiao"   => "bg-purple-500/10 text-purple-400 border-purple-500/30 shadow-[0_0_10px_rgba(168,85,247,0.2)]",
        "HoanThanh"  => "bg-[#00FF66]/10 text-[#00FF66] border-[#00FF66]/30 shadow-[0_0_10px_rgba(0,255,102,0.2)]",
        "DaHuy"      => "bg-red-500/10 text-red-500 border-red-500/30 shadow-[0_0_10px_rgba(239,68,68,0.2)]",
        _ => "bg-[#222] text-gray-400 border-[#333]"
    };
    string TenTrangThai(string s) => s switch {
        "ChoXacNhan" => "CHỜ XÁC NHẬN",
        "DangXuLy"   => "ĐANG XỬ LÝ",
        "DangGiao"   => "ĐANG GIAO",
        "HoanThanh"  => "HOÀN THÀNH",
        "DaHuy"      => "ĐÃ HỦY",
        _ => s.ToUpper()
    };
    string IconTrangThai(string s) => s switch {
        "ChoXacNhan" => "pending_actions",
        "DangXuLy"   => "sync",
        "DangGiao"   => "local_shipping",
        "HoanThanh"  => "check_circle",
        "DaHuy"      => "cancel",
        _ => "help"
    };
}

<style>
.order-card {
    background: #0D0D0D;
    border: 1px solid #1a1a1a;
    border-radius: 1.5rem;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
}
.order-card:hover {
    border-color: rgba(0,255,102,0.3);
    transform: translateY(-4px);
    box-shadow: 0 10px 40px -10px rgba(0,0,0,0.8), 0 0 20px rgba(0,255,102,0.05);
}
.order-card::before {
    content: ''; position: absolute; top: 0; left: 0; width: 4px; height: 100%;
    background: #252525; transition: all 0.3s ease;
}
.order-card:hover::before {
    background: #00FF66;
    box-shadow: 0 0 10px #00FF66;
}
.btn-cyber-outline {
    font-family: 'Space Grotesk', sans-serif; font-weight: 700;
    font-size: 0.75rem; letter-spacing: 0.15em; text-transform: uppercase;
    padding: 0.6rem 1.5rem;
    border: 1px solid rgba(0,255,102,0.3); color: #00FF66;
    border-radius: 0.5rem; background: rgba(0,255,102,0.05);
    transition: all 0.3s;
    display: inline-flex; items-center; justify-content: center; gap: 0.5rem;
}
.btn-cyber-outline:hover {
    background: #00FF66; color: #000;
    box-shadow: 0 0 20px rgba(0,255,102,0.4);
}
</style>

<div class="max-w-[1280px] mx-auto px-8 py-16 relative">
    <div class="absolute top-0 right-0 w-96 h-96 bg-[#00FF66] opacity-[0.03] blur-[120px] rounded-full pointer-events-none z-0"></div>
    
    <div class="relative z-10">
        <div class="flex items-center gap-4 mb-4">
            <div class="w-16 h-16 bg-[#0D0D0D] border border-[#222] rounded-2xl flex items-center justify-center shadow-xl relative overflow-hidden group">
                <div class="absolute inset-0 bg-[#00FF66]/10 opacity-0 group-hover:opacity-100 transition-opacity"></div>
                <span class="material-symbols-outlined text-[#00FF66] text-4xl">inventory_2</span>
            </div>
            <div>
                <h1 class="font-['Space_Grotesk'] text-4xl font-black text-white uppercase italic tracking-tighter">Quản lý Đơn hàng</h1>
                <p class="text-gray-500 text-sm tracking-widest uppercase font-bold mt-1">Lịch sử giao dịch BOMIXI</p>
            </div>
        </div>
        
        <div class="mb-12 h-px w-full bg-gradient-to-r from-[#252525] via-[#252525] to-transparent"></div>

        @if (!Model.Any())
        {
            <div class="bg-[#0D0D0D] border border-[#1a1a1a] rounded-[2rem] p-20 flex flex-col items-center justify-center text-center shadow-2xl relative overflow-hidden">
                <span class="material-symbols-outlined text-8xl text-[#222] mb-6">receipt_long</span>
                <h2 class="font-['Space_Grotesk'] text-3xl font-black text-white mb-3 tracking-wide">Trống rỗng</h2>
                <p class="text-gray-500 mb-10 max-w-md">Kho dữ liệu của chúng tôi chưa ghi nhận bất kỳ giao dịch nào từ bạn. Hãy trang bị vũ khí mới ngay hôm nay!</p>
                <a asp-controller="Home" asp-action="Index" class="btn-cyber" style="clip-path: polygon(15px 0, 100% 0, 100% calc(100% - 15px), calc(100% - 15px) 100%, 0 100%, 0 15px); background: #00FF66; color: #000; padding: 1rem 3rem; font-weight: 900;">
                    <span class="material-symbols-outlined">rocket_launch</span> Truy cập cửa hàng
                </a>
            </div>
        }
        else
        {
            <div class="grid grid-cols-1 gap-6">
                @foreach (var dh in Model.OrderByDescending(x => x.OrderDate))
                {
                    <div class="order-card p-6 md:p-8 flex flex-col lg:flex-row lg:items-center justify-between gap-8 pl-10 md:pl-12">
                        <div class="flex-1">
                            <div class="flex flex-wrap items-center gap-4 mb-3">
                                <h3 class="font-['Space_Grotesk'] font-bold text-white text-2xl tracking-wider">
                                    <span class="text-gray-600">#</span>@(dh.OrderNumber ?? dh.Id.ToString())
                                </h3>
                                <div class="flex items-center gap-1.5 px-3 py-1 rounded-full border @MauTrangThai(dh.Status)">
                                    <span class="material-symbols-outlined text-[14px]">@IconTrangThai(dh.Status)</span>
                                    <span class="font-['Space_Grotesk'] text-[10px] tracking-[0.2em] font-bold">@TenTrangThai(dh.Status)</span>
                                </div>
                            </div>
                            
                            <div class="flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-6 text-sm text-gray-500 mt-4">
                                <div class="flex items-center gap-2">
                                    <span class="material-symbols-outlined text-[16px] text-gray-600">calendar_today</span>
                                    @dh.OrderDate.ToString("HH:mm - dd/MM/yyyy")
                                </div>
                                <div class="hidden sm:block w-1 h-1 bg-[#333] rounded-full"></div>
                                <div class="flex items-center gap-2">
                                    <span class="material-symbols-outlined text-[16px] text-gray-600">category</span>
                                    @dh.OrderDetails.Count sản phẩm
                                </div>
                            </div>
                            
                            <div class="mt-4 pt-4 border-t border-[#1a1a1a] flex flex-col gap-2">
                                <div class="flex items-start gap-3 text-sm text-gray-400">
                                    <span class="material-symbols-outlined text-[18px] text-gray-600 mt-0.5">location_on</span>
                                    <span class="leading-relaxed">@dh.ShippingAddress</span>
                                </div>
                            </div>
                        </div>

                        <div class="lg:w-[300px] flex flex-col lg:items-end justify-between gap-6 border-t lg:border-t-0 lg:border-l border-[#1a1a1a] pt-6 lg:pt-0 lg:pl-8">
                            <div class="text-left lg:text-right w-full">
                                <p class="text-[10px] text-gray-500 uppercase font-bold tracking-[0.2em] mb-1">Tổng thanh toán</p>
                                <div class="font-['Space_Grotesk'] font-black text-[#00FF66] text-3xl tracking-tighter drop-shadow-[0_0_10px_rgba(0,255,102,0.3)]">
                                    @FormatTien(dh.TotalAmount)
                                </div>
                            </div>
                            
                            <div class="flex flex-col gap-3 w-full lg:w-auto">
                                <a asp-action="ChiTiet" asp-route-id="@dh.Id" class="btn-cyber-outline w-full lg:w-auto">
                                    <span class="material-symbols-outlined text-[18px]">terminal</span> CHI TIẾT
                                </a>
                                @if (dh.Status == "ChoXacNhan")
                                {
                                    <button onclick="huyDon(@dh.Id)"
                                            class="w-full lg:w-auto font-['Space_Grotesk'] text-[10px] tracking-[0.2em] font-bold uppercase text-red-400 border border-red-500/30 bg-red-500/5 hover:bg-red-500 hover:text-white px-4 py-3 rounded-lg transition-all">
                                        HỦY ĐƠN
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

@section Scripts {
<script>
async function huyDon(id) {
    if (!confirm('Bạn chắc chắn muốn hủy đơn hàng này? Tồn kho sẽ được hoàn lại.')) return;
    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
    const res = await fetch('/DonHang/HuyDon', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'RequestVerificationToken': token || '' },
        body: `id=${id}&lyDo=${encodeURIComponent('Khách hàng hủy từ trang danh sách đơn hàng')}`
    });
    const data = await res.json();
    alert(data.message || (data.success ? 'Đã hủy đơn.' : 'Không thể hủy đơn.'));
    if (data.success) location.reload();
}
</script>
@Html.AntiForgeryToken()
}
