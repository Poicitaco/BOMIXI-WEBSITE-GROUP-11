@model ShopLaptop_v1.Models.ApplicationUser
@{
    ViewData["Title"] = "Tài khoản của tôi";
}

<style>
.btn-cyber {
    background: #00FF66; color: #000;
    font-family: 'Space Grotesk', sans-serif; font-weight: 900;
    font-size: 0.8rem; letter-spacing: 0.1em; text-transform: uppercase;
    padding: 0.75rem 2rem;
    clip-path: polygon(10px 0, 100% 0, 100% calc(100% - 10px), calc(100% - 10px) 100%, 0 100%, 0 10px);
    transition: filter 0.2s, transform 0.2s;
    display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem;
    border: none; cursor: pointer;
}
.btn-cyber:hover { filter: brightness(1.2); transform: translateY(-2px); }

.btn-cyber-dark {
    background: #111; color: #fff; border: 1px solid #333;
    font-family: 'Space Grotesk', sans-serif; font-weight: 900;
    font-size: 0.8rem; letter-spacing: 0.1em; text-transform: uppercase;
    padding: 0.75rem 2rem;
    clip-path: polygon(10px 0, 100% 0, 100% calc(100% - 10px), calc(100% - 10px) 100%, 0 100%, 0 10px);
    transition: background 0.2s, border-color 0.2s;
    display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem;
    cursor: pointer;
}
.btn-cyber-dark:hover { background: #222; border-color: #00FF66; }

.input-cyber {
    width: 100%; background-color: #0a0a0a; border: 1px solid #222; border-radius: 8px;
    padding: 0.75rem 1rem; color: #fff; font-size: 0.9rem;
    transition: all 0.3s; outline: none;
}
.input-cyber:focus { border-color: #00FF66; box-shadow: 0 0 15px rgba(0,255,102,0.1); }
.input-cyber:disabled { background-color: #050505; color: #555; cursor: not-allowed; border-color: #111; }
</style>

<div class="max-w-[1000px] mx-auto px-8 py-12 relative">
    <!-- Hiệu ứng nền -->
    <div class="absolute top-0 right-0 w-96 h-96 bg-[#00FF66] opacity-5 blur-[120px] rounded-full pointer-events-none z-0"></div>

    <div class="relative z-10">
        <div class="flex items-center gap-3 mb-2">
            <span class="material-symbols-outlined text-[#00FF66] text-4xl">account_circle</span>
            <h1 class="font-['Space_Grotesk'] text-3xl font-black text-white uppercase italic tracking-tighter">Hồ sơ của bạn</h1>
        </div>
        <p class="text-gray-500 text-sm mb-10 tracking-wide">Quản lý thông tin cá nhân và bảo mật tài khoản BOMIXI</p>

        @if (TempData["ThanhCong"] != null)
        {
            <div class="bg-green-900/20 border-l-4 border-[#00FF66] rounded-r-lg p-4 mb-6 text-sm text-[#00FF66] flex items-center gap-3 font-medium">
                <span class="material-symbols-outlined">check_circle</span> @TempData["ThanhCong"]
            </div>
        }
        @if (TempData["ThatBai"] != null)
        {
            <div class="bg-red-900/20 border-l-4 border-red-500 rounded-r-lg p-4 mb-6 text-sm text-red-400 flex items-center gap-3 font-medium">
                <span class="material-symbols-outlined">error</span> @TempData["ThatBai"]
            </div>
        }

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <!-- Avatar + tóm tắt -->
            <div class="lg:col-span-1">
                <div class="bg-[#0D0D0D] border border-[#1a1a1a] rounded-2xl p-8 text-center shadow-2xl relative overflow-hidden group">
                    <div class="absolute inset-0 bg-gradient-to-b from-[#00FF66]/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>
                    
                    <div class="w-24 h-24 bg-[#111] border border-[#333] rounded-full flex items-center justify-center mx-auto mb-5 relative group-hover:border-[#00FF66] transition-colors duration-300">
                        <span class="material-symbols-outlined text-gray-400 group-hover:text-[#00FF66] text-5xl transition-colors duration-300">person</span>
                        <div class="absolute -bottom-1 -right-1 w-6 h-6 bg-[#00FF66] rounded-full flex items-center justify-center border-2 border-[#0D0D0D]">
                            <span class="material-symbols-outlined text-black text-[12px]">edit</span>
                        </div>
                    </div>
                    
                    <p class="font-['Space_Grotesk'] font-bold text-white text-xl tracking-wide">@(Model.FullName ?? "Thành viên")</p>
                    <p class="text-gray-500 text-sm truncate mt-1">@Model.Email</p>
                    
                    <div class="mt-4">
                        @if (User.IsInRole("QuanTri"))
                        {
                            <span class="inline-flex items-center gap-1 font-['Space_Grotesk'] text-[10px] font-bold tracking-[0.2em] uppercase text-[#00FF66] bg-[#00FF66]/10 px-4 py-1.5 rounded-full border border-[#00FF66]/20">
                                <span class="material-symbols-outlined text-[12px]">shield_person</span> Quản trị viên
                            </span>
                        }
                        else
                        {
                            <span class="inline-flex items-center gap-1 font-['Space_Grotesk'] text-[10px] font-bold tracking-[0.2em] uppercase text-gray-300 bg-[#222] px-4 py-1.5 rounded-full border border-[#333]">
                                <span class="material-symbols-outlined text-[12px]">person</span> Thành viên
                            </span>
                        }
                    </div>

                    <div class="border-t border-[#1a1a1a] mt-8 pt-6 space-y-2">
                        <a asp-controller="DonHang" asp-action="DanhSach"
                           class="flex items-center justify-between px-4 py-3 bg-[#111] hover:bg-[#1a1a1a] rounded-xl text-sm text-gray-400 hover:text-white transition-colors">
                            <div class="flex items-center gap-3"><span class="material-symbols-outlined text-[18px]">receipt_long</span> Lịch sử đơn hàng</div>
                            <span class="material-symbols-outlined text-[16px]">chevron_right</span>
                        </a>
                        @if (User.IsInRole("QuanTri"))
                        {
                            <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index"
                               class="flex items-center justify-between px-4 py-3 bg-[#00FF66]/5 hover:bg-[#00FF66]/10 border border-[#00FF66]/20 rounded-xl text-sm text-[#00FF66] transition-colors">
                                <div class="flex items-center gap-3"><span class="material-symbols-outlined text-[18px]">admin_panel_settings</span> Bảng điều khiển</div>
                                <span class="material-symbols-outlined text-[16px]">chevron_right</span>
                            </a>
                        }
                    </div>
                </div>
            </div>

            <!-- Form thông tin + đổi mật khẩu -->
            <div class="lg:col-span-2 space-y-8">
                <!-- Thông tin cá nhân -->
                <div class="bg-[#0D0D0D] border border-[#1a1a1a] rounded-2xl p-8 shadow-2xl">
                    <div class="flex items-center gap-3 mb-6 pb-4 border-b border-[#1a1a1a]">
                        <span class="material-symbols-outlined text-gray-400">badge</span>
                        <h2 class="font-['Space_Grotesk'] font-bold text-white text-lg tracking-wider uppercase">Chi tiết hồ sơ</h2>
                    </div>
                    
                    <form asp-action="CapNhatHoSo" method="post" class="space-y-5">
                        @Html.AntiForgeryToken()
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                            <div>
                                <label class="text-[10px] text-gray-500 uppercase font-bold tracking-widest block mb-2">Họ và tên</label>
                                <input name="hoTen" type="text" value="@Model.FullName" class="input-cyber" placeholder="Nguyễn Văn A" />
                            </div>
                            <div>
                                <label class="text-[10px] text-gray-500 uppercase font-bold tracking-widest block mb-2">Số điện thoại</label>
                                <input name="soDienThoai" type="tel" value="@Model.PhoneNumber" class="input-cyber" placeholder="0901234567" />
                            </div>
                        </div>
                        <div>
                            <label class="text-[10px] text-gray-500 uppercase font-bold tracking-widest block mb-2">Địa chỉ giao hàng mặc định</label>
                            <div class="relative">
                                <span class="material-symbols-outlined absolute left-3 top-3.5 text-gray-500 text-lg">location_on</span>
                                <input name="diaChi" type="text" value="@Model.Address" class="input-cyber pl-10" placeholder="Số nhà, đường, phường/xã..." />
                            </div>
                        </div>
                        <div>
                            <label class="text-[10px] text-gray-500 uppercase font-bold tracking-widest block mb-2">Email đăng nhập</label>
                            <div class="relative">
                                <span class="material-symbols-outlined absolute left-3 top-3.5 text-gray-600 text-lg">mail</span>
                                <input type="email" value="@Model.Email" disabled class="input-cyber pl-10" />
                            </div>
                        </div>
                        <div class="pt-4 flex justify-end">
                            <button type="submit" class="btn-cyber">
                                <span class="material-symbols-outlined text-[18px]">save</span> Lưu thay đổi
                            </button>
                        </div>
                    </form>
                </div>

                <!-- Đổi mật khẩu -->
                <div class="bg-[#0D0D0D] border border-[#1a1a1a] rounded-2xl p-8 shadow-2xl">
                    <div class="flex items-center gap-3 mb-6 pb-4 border-b border-[#1a1a1a]">
                        <span class="material-symbols-outlined text-gray-400">security</span>
                        <h2 class="font-['Space_Grotesk'] font-bold text-white text-lg tracking-wider uppercase">Bảo mật</h2>
                    </div>
                    
                    <form asp-action="DoiMatKhau" method="post" class="space-y-5">
                        @Html.AntiForgeryToken()
                        <div>
                            <label class="text-[10px] text-gray-500 uppercase font-bold tracking-widest block mb-2">Mật khẩu hiện tại</label>
                            <input name="matKhauCu" type="password" required class="input-cyber" placeholder="••••••••" />
                        </div>
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                            <div>
                                <label class="text-[10px] text-gray-500 uppercase font-bold tracking-widest block mb-2">Mật khẩu mới</label>
                                <input name="matKhauMoi" type="password" required class="input-cyber" placeholder="Mật khẩu an toàn" />
                            </div>
                            <div>
                                <label class="text-[10px] text-gray-500 uppercase font-bold tracking-widest block mb-2">Xác nhận mật khẩu mới</label>
                                <input name="xacNhanMatKhau" type="password" required class="input-cyber" placeholder="Nhập lại mật khẩu mới" />
                            </div>
                        </div>
                        <div class="pt-4 flex justify-end">
                            <button type="submit" class="btn-cyber-dark">
                                <span class="material-symbols-outlined text-[18px]">lock_reset</span> Đổi mật khẩu
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
