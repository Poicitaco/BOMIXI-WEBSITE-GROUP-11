<!DOCTYPE html>
<html lang="vi" class="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["MetaTitle"] ?? ViewData["Title"] + " - BOMIXI")</title>
    <meta name="description" content="@(ViewData["MetaDescription"] ?? "BOMIXI - Cửa hàng Laptop cao cấp hàng đầu Việt Nam. Bảo hành 24 tháng, giao hàng toàn quốc.")" />
    <meta name="robots" content="index, follow" />
    <meta property="og:title" content="@(ViewData["MetaTitle"] ?? "BOMIXI - Laptop Chính Hãng")" />
    <meta property="og:description" content="@(ViewData["MetaDescription"] ?? "BOMIXI - Cửa hàng Laptop cao cấp hàng đầu Việt Nam.")" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Be+Vietnam+Pro:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/tailwind.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
    <style>
        :root {
            --accent-cyber-lime: #C6FF00;
        }
        body {
            font-family: 'Be Vietnam Pro', sans-serif;
            background-color: #050505;
            background-image: 
                linear-gradient(rgba(255, 255, 255, 0.02) 1px, transparent 1px),
                linear-gradient(90deg, rgba(255, 255, 255, 0.02) 1px, transparent 1px);
            background-size: 40px 40px;
            position: relative;
            min-height: 100vh;
        }
        body::before {
            content: "";
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: radial-gradient(circle at 50% -20%, rgba(198, 255, 0, 0.08), transparent 70%),
                        radial-gradient(circle at 0% 100%, rgba(0, 255, 255, 0.03), transparent 50%);
            pointer-events: none;
            z-index: -1;
        }
        .cyber-grid {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, rgba(255,255,255,0.01) 1px, transparent 1px),
                        linear-gradient(180deg, rgba(255,255,255,0.01) 1px, transparent 1px);
            background-size: 100px 100px;
            pointer-events: none;
            z-index: -1;
            mask-image: radial-gradient(ellipse at center, black, transparent 80%);
        }
    </style>
</head>
<body class="antialiased text-white">
    <div class="cyber-grid"></div>

@inject ShopLaptop_v1.Services.SystemSettingService SettingService
@{
    var fsText = await SettingService.GetValueAsync("FlashSale_Text", "FLASH SALE - GIẢM 20% CHO ĐƠN HÀNG TRÊN 20 TRIỆU");
    var fsEnd = await SettingService.GetValueAsync("FlashSale_EndDate", DateTime.Today.AddDays(1).ToString("yyyy-MM-dd HH:mm:ss"));
    var fsActive = await SettingService.IsActiveAsync("FlashSale_IsActive");
}

@if (fsActive)
{
    <!-- FLASH SALE BAR -->
    <div id="flash-sale-bar" style="background:linear-gradient(90deg,#00FF66,#00cc52);color:#000;text-align:center;padding:0.4rem 1rem;font-family:'Space Grotesk',sans-serif;font-size:0.72rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;position:relative;z-index:60;">
        <span>@fsText</span>
        <span style="margin:0 1rem;">|</span>
        <span>KẾT THÚC TRONG: <span id="dem-nguoc-flash" style="font-size:0.85rem;letter-spacing:0.05em;">00:00:00</span></span>
        <button onclick="document.getElementById('flash-sale-bar').style.display='none'" style="position:absolute;right:1rem;top:50%;transform:translateY(-50%);background:none;border:none;color:#000;cursor:pointer;font-size:1rem;line-height:1;display:flex;align-items:center;">
            <span class="material-symbols-outlined text-[18px]">close</span>
        </button>
    </div>

    <script>
        (function() {
            const endTime = new Date("@fsEnd").getTime();
            function updateFS() {
                const now = new Date().getTime();
                const diff = Math.max(0, endTime - now);
                const h = Math.floor(diff / 3600000);
                const m = Math.floor((diff % 3600000) / 60000);
                const s = Math.floor((diff % 60000) / 1000);
                const timer = document.getElementById('dem-nguoc-flash');
                if (timer) timer.textContent = `${String(h).padStart(2, '0')}:${String(m).padStart(2, '0')}:${String(s).padStart(2, '0')}`;
            }
            setInterval(updateFS, 1000);
            updateFS();
        })();
    </script>
}

<!-- HEADER -->
<header class="fixed top-0 left-0 w-full z-50 bg-black/95 backdrop-blur-md border-b border-[#252525]">
    <div class="max-w-[1280px] mx-auto flex justify-between items-center px-8 h-20">
        <a asp-controller="Home" asp-action="Index"
           class="text-2xl font-black italic tracking-tighter text-accent-cyber-lime font-['Space_Grotesk']">
            BOMIXI
        </a>
        <nav class="hidden md:flex items-center gap-8">
            <a asp-controller="Home" asp-action="Index"
               class="font-['Space_Grotesk'] tracking-tight @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "text-accent-cyber-lime border-b-2 border-accent-cyber-lime pb-1" : "text-gray-400 hover:text-white transition-colors")">
                Laptop
            </a>
            <a asp-controller="GioHang" asp-action="Index"
               class="font-['Space_Grotesk'] tracking-tight @(ViewContext.RouteData.Values["controller"]?.ToString() == "GioHang" ? "text-accent-cyber-lime border-b-2 border-accent-cyber-lime pb-1" : "text-gray-400 hover:text-white transition-colors")">
                Giỏ Hàng
            </a>
            <a href="#" class="font-['Space_Grotesk'] tracking-tight text-gray-400 hover:text-white transition-colors">Blog</a>
            <a href="#" class="font-['Space_Grotesk'] tracking-tight text-gray-400 hover:text-white transition-colors">Hỗ Trợ</a>
        </nav>
        <div class="flex items-center gap-6">
            <!-- Tìm kiếm -->
