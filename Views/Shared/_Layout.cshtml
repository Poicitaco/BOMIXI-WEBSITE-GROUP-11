                            }
                        </div>
                        
                        <div class="py-2">
                            <a asp-controller="TaiKhoan" asp-action="HoSo" class="flex items-center px-4 py-2.5 text-sm text-gray-300 hover:bg-[#1A1A1A] hover:text-white transition-colors">
