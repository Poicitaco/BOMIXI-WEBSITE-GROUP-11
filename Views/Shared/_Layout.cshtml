                <!-- Popup Gợi ý -->
                <div id="search-suggestions" class="absolute top-full right-0 w-[300px] lg:w-[350px] bg-[#0D0D0D] border border-[#252525] rounded-lg mt-2 overflow-hidden hidden shadow-[0_10px_30px_rgba(0,0,0,0.8)] z-50">
                    <div id="search-results-container" class="max-h-[400px] overflow-y-auto"></div>
                </div>
            </div>
            <!-- So sánh -->
            @{
                var soSanhList = Context.Session.Get<List<int>>("SoSanh_Session") ?? new List<int>();
                var soSanhCount = soSanhList.Count;
            }
            <a asp-controller="SoSanh" asp-action="Index" class="text-white hover:text-accent-cyber-lime transition-colors relative" id="so-sanh-icon" title="So sánh sản phẩm">
                <span class="material-symbols-outlined">compare</span>
                <span class="absolute -top-2 -right-2 bg-[#252525] border border-[#333] text-accent-cyber-lime text-[10px] font-bold w-5 h-5 rounded-full flex items-center justify-center @(soSanhCount == 0 ? "hidden" : "")" id="so-sanh-count">@soSanhCount</span>
            </a>

            <!-- Yeu thich -->
            @if (User.Identity!.IsAuthenticated)
            {
                <a asp-controller="YeuThich" asp-action="Index" class="text-white hover:text-accent-cyber-lime transition-colors relative" id="yeu-thich-icon" title="Sản phẩm yêu thích">
