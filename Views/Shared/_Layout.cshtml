                                </a>
                            </div>
                        }
                        
                        <div class="border-t border-[#1A1A1A] py-1 bg-[#111]">
                            <form method="post" action="/Identity/Account/Logout">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="w-full flex items-center px-4 py-3 text-sm text-red-400 hover:bg-red-500/10 transition-colors font-bold">
                                    <span class="material-symbols-outlined text-[18px] mr-3">logout</span>Đăng xuất
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <a href="/Identity/Account/Login" class="text-white hover:text-accent-cyber-lime transition-colors">
                    <span class="material-symbols-outlined">account_circle</span>
                </a>
            }
        </div>
    </div>
</header>

<!-- NỘI DUNG CHÍNH -->
