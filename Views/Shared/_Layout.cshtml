<div id="toast-container" class="fixed bottom-5 right-5 z-50 flex flex-col gap-3"></div>

<script>
    // Hàm hiển thị Toast chuyên nghiệp
    function showToast(message, type = 'success') {
        const container = document.getElementById('toast-container');
        const toast = document.createElement('div');
        
        let icon = 'check_circle';
        let borderColor = 'border-green-500';
        let textColor = 'text-green-500';
        
        if (type === 'error') {
            icon = 'error';
            borderColor = 'border-red-500';
            textColor = 'text-red-500';
        } else if (type === 'info') {
            icon = 'info';
            borderColor = 'border-accent-electric-blue';
            textColor = 'text-accent-electric-blue';
        }
        
        toast.className = `flex items-center gap-3 min-w-[300px] bg-[#111] border-l-4 ${borderColor} text-white px-4 py-3 rounded-r-lg shadow-[0_4px_20px_rgba(0,0,0,0.5)] transition-all duration-300  text-sm`;
        toast.style.transform = 'translateX(100%)';
        toast.style.opacity = '0';
        
        toast.innerHTML = `
            <span class="material-symbols-outlined ${textColor}">${icon}</span>
            <span class="flex-grow">${message}</span>
            <button onclick="this.parentElement.remove()" class="text-gray-500 hover:text-white transition-colors">
                <span class="material-symbols-outlined text-sm">close</span>
            </button>
        `;
        
        container.appendChild(toast);
        
        // Trigger animation
        setTimeout(() => {
            toast.style.transform = 'translateX(0)';
            toast.style.opacity = '1';
        }, 10);
        
        // Tự động tắt sau 3 giây
        setTimeout(() => {
            toast.style.transform = 'translateX(100%)';
            toast.style.opacity = '0';
            setTimeout(() => {
                toast.remove();
            }, 300);
        }, 3000);
    }

    // Cập nhật số lượng giỏ hàng động
    function capNhatSoLuongGioHang(soLuong) {
        const badge = document.getElementById('gio-hang-count');
        if (badge) {
            badge.textContent = soLuong;
            if (soLuong > 0) badge.classList.remove('hidden');
            else badge.classList.add('hidden');
        }
    }
    // Auto-suggest tìm kiếm
    document.addEventListener('DOMContentLoaded', function() {
        const searchInput = document.getElementById('search-input');
        const suggestionsBox = document.getElementById('search-suggestions');
        const resultsContainer = document.getElementById('search-results-container');
        let searchTimeout = null;

        if (searchInput) {
            searchInput.addEventListener('input', function(e) {
                clearTimeout(searchTimeout);
                const query = e.target.value.trim();

                if (query.length < 2) {
                    suggestionsBox.classList.add('hidden');
                    return;
                }

                searchTimeout = setTimeout(async () => {
                    try {
                        const response = await fetch(`/Home/GoiYTimKiem?tuKhoa=${encodeURIComponent(query)}`);
                        const data = await response.json();
                        
                        if (data && data.length > 0) {
                            resultsContainer.innerHTML = '';
                            data.forEach(item => {
                                const giaFormat = new Intl.NumberFormat('vi-VN').format(item.gia) + ' VNĐ';
                                const hinhAnh = item.hinhAnh ? item.hinhAnh : '/images/placeholder.png';
                                
                                const html = `
                                    <a href="/Home/ChiTiet/${item.id}" class="flex items-center gap-3 p-3 hover:bg-[#1A1A1A] transition-colors border-b border-[#1A1A1A] last:border-b-0">
                                        <div class="w-12 h-12 bg-white flex items-center justify-center rounded overflow-hidden flex-shrink-0">
                                            <img src="${hinhAnh}" class="max-w-full max-h-full object-contain" alt="${item.ten}" onerror="this.src='/images/placeholder.png'" />
                                        </div>
                                        <div class="flex-grow min-w-0">
                                            <div class="text-white text-sm font-semibold truncate font-['Space_Grotesk']">${item.ten}</div>
                                            <div class="text-accent-cyber-lime text-xs font-bold mt-1">${giaFormat}</div>
                                        </div>
                                    </a>
                                `;
                                resultsContainer.insertAdjacentHTML('beforeend', html);
                            });
                            suggestionsBox.classList.remove('hidden');
                        } else {
                            resultsContainer.innerHTML = `
                                <div class="p-4 text-center text-sm text-gray-500 ">
                                    Không tìm thấy sản phẩm nào phù hợp.
                                </div>
                            `;
                            suggestionsBox.classList.remove('hidden');
                        }
                    } catch (err) {
                        console.error('Lỗi tìm kiếm:', err);
                    }
                }, 400); // delay 400ms
            });

            // Ẩn khi click ra ngoài
            document.addEventListener('click', function(e) {
                if (!searchInput.contains(e.target) && !suggestionsBox.contains(e.target)) {
                    suggestionsBox.classList.add('hidden');
                }
            });
            
            // Hiện lại khi focus vào ô tìm kiếm có dữ liệu
            searchInput.addEventListener('focus', function() {
                if (this.value.trim().length >= 2) {
                    suggestionsBox.classList.remove('hidden');
                }
            });
        }
    });
</script>

<!-- RECENTLY VIEWED SECTION -->
<div id="da-xem-section" style="display:none; background:#0a0a0a; border-top:1px solid #1a1a1a; padding:2.5rem 0;">
    <div style="max-width:1280px; margin:0 auto; padding:0 2rem;">
        <h3 style="font-family:'Space Grotesk',sans-serif; font-size:0.7rem; font-weight:700; color:#00FF66; letter-spacing:0.2em; text-transform:uppercase; margin-bottom:1.25rem;">DA XEM GAN DAY</h3>
        <div id="da-xem-grid" style="display:grid; grid-template-columns:repeat(auto-fill,minmax(160px,1fr)); gap:1rem;"></div>
    </div>
</div>

<script>
    // Flash Sale Countdown - dem nguoc den nua dem
    (function() {
        function capNhatDemNguoc() {
            const el = document.getElementById('dem-nguoc-flash');
            if (!el) return;
            const now = new Date();
            const ketThuc = new Date();
            ketThuc.setHours(23, 59, 59, 0);
            const con = Math.max(0, ketThuc - now);
            const gio = Math.floor(con / 3600000);
            const phut = Math.floor((con % 3600000) / 60000);
            const giay = Math.floor((con % 60000) / 1000);
            el.textContent = [gio, phut, giay].map(n => String(n).padStart(2, '0')).join(':');
        }
        capNhatDemNguoc();
        setInterval(capNhatDemNguoc, 1000);
    })();

    // Recently Viewed - tai va hien thi
    (function() {
        async function taiDaXem() {
            try {
                const res = await fetch('/Home/LaySanPhamDaXem');
                const data = await res.json();
                if (!data || data.length === 0) return;
                const section = document.getElementById('da-xem-section');
                const grid = document.getElementById('da-xem-grid');
                if (!section || !grid) return;
                grid.innerHTML = data.map(sp => `
                    <a href="/Home/ChiTiet/${sp.id}" style="display:block;background:#111;border:1px solid #252525;border-radius:8px;overflow:hidden;text-decoration:none;transition:border-color 0.2s,transform 0.2s;" onmouseover="this.style.borderColor='rgba(0,255,102,0.4)';this.style.transform='translateY(-2px)';" onmouseout="this.style.borderColor='#252525';this.style.transform='none';">
                        <div style="height:110px;background:#000;display:flex;align-items:center;justify-content:center;padding:0.75rem;">
                            <img src="${sp.hinhAnh}" alt="${sp.ten}" style="max-width:100%;max-height:100%;object-fit:contain;" loading="lazy" onerror="this.style.display='none'">
                        </div>
                        <div style="padding:0.6rem 0.75rem;">
                            <div style="font-family:'Space Grotesk',sans-serif;font-size:0.7rem;font-weight:600;color:#fff;line-height:1.3;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;">${sp.ten}</div>
                            <div style="font-family:'Space Grotesk',sans-serif;font-size:0.7rem;font-weight:700;color:#00FF66;margin-top:0.25rem;">${sp.giaFormat}</div>
                        </div>
                    </a>
                `).join('');
                section.style.display = 'block';
            } catch(e) { /* silent fail */ }
        }
        document.addEventListener('DOMContentLoaded', taiDaXem);
    })();

    // Cap nhat badge Yeu thich
    @if (User.Identity!.IsAuthenticated) {
        <text>
    document.addEventListener('DOMContentLoaded', async function() {
        try {
            const res = await fetch('/YeuThich/KiemTraTrangThai?id=0');
            const data = await res.json();
            const badge = document.getElementById('yeu-thich-count');
            if (badge && data.tongSo > 0) {
                badge.textContent = data.tongSo;
                badge.style.display = 'flex';
            }
        } catch(e) {}
    });
        </text>
    }
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
