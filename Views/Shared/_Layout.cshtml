                            </a>
                            <a asp-controller="DonHang" asp-action="DanhSach" class="flex items-center px-4 py-2.5 text-sm text-gray-300 hover:bg-[#1A1A1A] hover:text-white transition-colors">
                                <span class="material-symbols-outlined text-[18px] mr-3 text-gray-400">receipt_long</span>Lịch sử mua hàng
                            </a>
                        </div>

                        @if (User.IsInRole("QuanTri"))
                        {
                            <div class="border-t border-[#1A1A1A] py-2 bg-[#050505]">
                                <div class="px-4 py-1.5">
                                    <span class="text-[9px] text-gray-600 uppercase font-bold tracking-[0.2em]">Quản trị trung tâm</span>
                                </div>
                                <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="flex items-center px-4 py-2.5 text-sm text-gray-300 hover:bg-[#111] hover:text-white transition-colors border-l-2 border-transparent hover:border-[#00FF66]">
                                    <span class="material-symbols-outlined text-[18px] mr-3 text-[#00FF66]">monitoring</span>Bảng điều khiển
                                </a>
                                <a asp-area="Admin" asp-controller="QuanLySanPham" asp-action="Index" class="flex items-center px-4 py-2.5 text-sm text-gray-300 hover:bg-[#111] hover:text-white transition-colors border-l-2 border-transparent hover:border-[#00FF66]">
                                    <span class="material-symbols-outlined text-[18px] mr-3 text-gray-400">inventory_2</span>Kho & Sản phẩm
                                </a>
                                <a asp-area="Admin" asp-controller="QuanLyDonHang" asp-action="Index" class="flex items-center px-4 py-2.5 text-sm text-gray-300 hover:bg-[#111] hover:text-white transition-colors border-l-2 border-transparent hover:border-[#00FF66]">
                                    <span class="material-symbols-outlined text-[18px] mr-3 text-gray-400">local_shipping</span>Xử lý Đơn hàng
                                </a>
                                <a asp-area="Admin" asp-controller="QuanLyDanhMuc" asp-action="Index" class="flex items-center px-4 py-2.5 text-sm text-gray-300 hover:bg-[#111] hover:text-white transition-colors border-l-2 border-transparent hover:border-[#00FF66]">
                                    <span class="material-symbols-outlined text-[18px] mr-3 text-gray-400">category</span>Hãng & Danh mục
                                </a>
                                <a asp-area="Admin" asp-controller="QuanLyBanner" asp-action="Index" class="flex items-center px-4 py-2.5 text-sm text-gray-300 hover:bg-[#111] hover:text-white transition-colors border-l-2 border-transparent hover:border-[#00FF66]">
                                    <span class="material-symbols-outlined text-[18px] mr-3 text-gray-400">view_carousel</span>Banner & UI
                                </a>
                                <a asp-area="Admin" asp-controller="QuanLySetting" asp-action="Index" class="flex items-center px-4 py-2.5 text-sm text-gray-300 hover:bg-[#111] hover:text-white transition-colors border-l-2 border-transparent hover:border-[#00FF66]">
