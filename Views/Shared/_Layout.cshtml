                    <span class="absolute -top-2 -right-2 bg-red-500 text-white text-[10px] font-bold w-5 h-5 rounded-full items-center justify-center hidden" id="yeu-thich-count">0</span>
                </a>
            }

            <!-- Giỏ hàng -->
