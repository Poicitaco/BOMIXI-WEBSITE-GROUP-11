@page
@model ShopLaptop_v1.Areas.Identity.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Đăng ký tài khoản";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi" class="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BOMIXI</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/tailwind.css" asp-append-version="true" />
</head>
<body class="bg-black min-h-screen flex items-center justify-center p-4">
    <!-- Hiệu ứng nền -->
    <div class="fixed inset-0 overflow-hidden pointer-events-none">
        <div class="absolute -top-40 -right-40 w-96 h-96 bg-accent-cyber-lime/5 rounded-full blur-3xl"></div>
        <div class="absolute -bottom-40 -left-40 w-96 h-96 bg-accent-electric-blue/5 rounded-full blur-3xl"></div>
    </div>

    <div class="w-full max-w-md relative z-10">
        <!-- Logo -->
        <div class="text-center mb-8">
            <a href="/" class="text-3xl font-black italic tracking-tighter text-accent-cyber-lime font-['Space_Grotesk']">BOMIXI</a>
            <p class=" text-gray-500 text-sm mt-2">Tạo tài khoản mới để bắt đầu mua sắm</p>
        </div>

        <!-- Card đăng ký -->
        <div class="bg-[#0D0D0D] border border-[#252525] rounded-xl p-8">
            <h1 class="font-['Space_Grotesk'] text-2xl font-bold text-white mb-6">Đăng ký</h1>

            <form id="registerForm" asp-page="/Account/Register" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                <div asp-validation-summary="ModelOnly" class="bg-red-900/20 border border-red-900/40 rounded-lg p-3 mb-4  text-sm text-red-400 hidden"></div>

                <!-- Họ tên -->
                <div class="mb-4">
                    <label asp-for="Input.FullName" class=" text-xs text-gray-400 uppercase tracking-widest block mb-2">Họ và tên</label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-3 top-3 text-gray-500 text-sm">person</span>
                        <input asp-for="Input.FullName" type="text"
                               class="w-full bg-[#1A1A1A] border border-[#252525] rounded-lg pl-10 pr-4 py-3 text-white  text-sm focus:outline-none focus:border-accent-cyber-lime transition-all placeholder:text-gray-600"
                               placeholder="Nguyễn Văn A" />
                    </div>
                </div>

                <!-- Email -->
                <div class="mb-4">
                    <label asp-for="Input.Email" class=" text-xs text-gray-400 uppercase tracking-widest block mb-2">Email</label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-3 top-3 text-gray-500 text-sm">email</span>
                        <input asp-for="Input.Email" type="email" autocomplete="username"
                               class="w-full bg-[#1A1A1A] border border-[#252525] rounded-lg pl-10 pr-4 py-3 text-white  text-sm focus:outline-none focus:border-accent-cyber-lime transition-all placeholder:text-gray-600"
                               placeholder="example@email.com" />
                    </div>
                    <span asp-validation-for="Input.Email" class=" text-xs text-red-400 mt-1 block"></span>
                </div>

                <!-- Mật khẩu -->
                <div class="mb-4">
                    <label asp-for="Input.Password" class=" text-xs text-gray-400 uppercase tracking-widest block mb-2">Mật khẩu</label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-3 top-3 text-gray-500 text-sm">lock</span>
                        <input asp-for="Input.Password" type="password" autocomplete="new-password"
                               class="w-full bg-[#1A1A1A] border border-[#252525] rounded-lg pl-10 pr-4 py-3 text-white  text-sm focus:outline-none focus:border-accent-cyber-lime transition-all placeholder:text-gray-600"
                               placeholder="Ít nhất 6 ký tự" />
                    </div>
                    <span asp-validation-for="Input.Password" class=" text-xs text-red-400 mt-1 block"></span>
                </div>

                <!-- Xác nhận mật khẩu -->
                <div class="mb-6">
                    <label asp-for="Input.ConfirmPassword" class=" text-xs text-gray-400 uppercase tracking-widest block mb-2">Xác nhận mật khẩu</label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-3 top-3 text-gray-500 text-sm">lock_reset</span>
                        <input asp-for="Input.ConfirmPassword" type="password" autocomplete="new-password"
                               class="w-full bg-[#1A1A1A] border border-[#252525] rounded-lg pl-10 pr-4 py-3 text-white  text-sm focus:outline-none focus:border-accent-cyber-lime transition-all placeholder:text-gray-600"
                               placeholder="Nhập lại mật khẩu" />
                    </div>
                    <span asp-validation-for="Input.ConfirmPassword" class=" text-xs text-red-400 mt-1 block"></span>
                </div>

                <button type="submit"
                        class="w-full bg-accent-cyber-lime hover:opacity-90 active:scale-95 text-black font-['Space_Grotesk'] font-bold py-3 rounded-lg transition-all flex items-center justify-center gap-2">
                    <span class="material-symbols-outlined text-sm">how_to_reg</span>
                    TẠO TÀI KHOẢN
                </button>
            </form>

            <div class="mt-6 text-center">
                <p class=" text-sm text-gray-500">
                    Đã có tài khoản?
                    <a asp-page="./Login" class="text-accent-cyber-lime hover:underline font-medium">Đăng nhập ngay</a>
                </p>
            </div>
        </div>

        <!-- Quay lại trang chủ -->
        <div class="text-center mt-6">
            <a href="/" class=" text-sm text-gray-600 hover:text-gray-400 transition-colors">
                ← Quay lại trang chủ
            </a>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>
