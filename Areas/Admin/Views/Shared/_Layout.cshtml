<!DOCTYPE html>
<html lang="vi" class="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BOMIXI Admin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/tailwind.css" asp-append-version="true" />
    <style>
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; display: inline-block; vertical-align: middle; }
        .nav-item-active { background-color: rgba(204,255,0,0.1); color: #CCFF00; border-left: 2px solid #CCFF00; }
    </style>
</head>
<body class="bg-[#0A0A0A] text-white antialiased flex">
    <!-- SIDEBAR -->
    <aside class="w-60 min-h-screen bg-[#0D0D0D] border-r border-[#1A1A1A] flex flex-col fixed top-0 left-0 z-30">
        <div class="px-6 py-5 border-b border-[#1A1A1A]">
            <a href="/" class="text-xl font-black italic tracking-tighter text-accent-cyber-lime font-['Space_Grotesk']">BOMIXI</a>
            <span class="block font-['Space_Grotesk'] text-[9px] tracking-widest text-gray-600 uppercase mt-0.5">Admin Panel</span>
        </div>
        <nav class="flex-1 py-4 space-y-1 px-3">
            @{
                string ctrl = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
                string NavClass(string c) => ctrl == c ? "nav-item-active" : "text-gray-500 hover:text-white hover:bg-[#1A1A1A]";
            }
            <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index"
               class="flex items-center gap-3 px-3 py-2.5 rounded-lg transition-all  text-sm @NavClass("Dashboard")">
                <span class="material-symbols-outlined text-xl">dashboard</span> Dashboard
            </a>
            <a asp-area="Admin" asp-controller="QuanLySanPham" asp-action="Index"
               class="flex items-center gap-3 px-3 py-2.5 rounded-lg transition-all  text-sm @NavClass("QuanLySanPham")">
                <span class="material-symbols-outlined text-xl">laptop</span> Sản phẩm
            </a>
            <a asp-area="Admin" asp-controller="QuanLyDanhMuc" asp-action="Index"
               class="flex items-center gap-3 px-3 py-2.5 rounded-lg transition-all  text-sm @NavClass("QuanLyDanhMuc")">
                <span class="material-symbols-outlined text-xl">category</span> Hãng / Danh mục
            </a>
            <a asp-area="Admin" asp-controller="QuanLyDonHang" asp-action="Index"
               class="flex items-center gap-3 px-3 py-2.5 rounded-lg transition-all  text-sm @NavClass("QuanLyDonHang")">
                <span class="material-symbols-outlined text-xl">receipt_long</span> Đơn hàng
            </a>
            <a asp-area="Admin" asp-controller="QuanLyBanner" asp-action="Index"
               class="flex items-center gap-3 px-3 py-2.5 rounded-lg transition-all  text-sm @NavClass("QuanLyBanner")">
                <span class="material-symbols-outlined text-xl">ad_units</span> Banner quảng cáo
            </a>
            <a asp-area="Admin" asp-controller="QuanLySetting" asp-action="Index"
               class="flex items-center gap-3 px-3 py-2.5 rounded-lg transition-all  text-sm @NavClass("QuanLySetting")">
                <span class="material-symbols-outlined text-xl">settings</span> Cấu hình hệ thống
            </a>
            <div class="border-t border-[#1A1A1A] my-3"></div>
            <a href="/" class="flex items-center gap-3 px-3 py-2.5 rounded-lg transition-all  text-sm text-gray-500 hover:text-white hover:bg-[#1A1A1A]">
                <span class="material-symbols-outlined text-xl">store</span> Xem cửa hàng
            </a>
        </nav>
        <div class="border-t border-[#1A1A1A] p-4">
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 bg-accent-cyber-lime/20 rounded-full flex items-center justify-center">
                    <span class="material-symbols-outlined text-accent-cyber-lime text-sm">admin_panel_settings</span>
                </div>
                <div>
                    <p class=" text-xs text-white font-medium">@User.Identity!.Name?.Split('@')[0]</p>
                    <p class=" text-[10px] text-accent-cyber-lime">Quản trị viên</p>
                </div>
            </div>
        </div>
    </aside>

    <!-- MAIN CONTENT -->
    <div class="flex-1 ml-60">
        <!-- Top bar -->
        <header class="h-14 bg-[#0D0D0D] border-b border-[#1A1A1A] flex items-center justify-between px-8 sticky top-0 z-20">
            <h1 class="font-['Space_Grotesk'] font-semibold text-white text-sm">@ViewData["Title"]</h1>
            <div class="flex items-center gap-4">
                <form method="post" action="/Identity/Account/Logout">
                    @Html.AntiForgeryToken()
                    <button type="submit" class=" text-xs text-gray-500 hover:text-red-400 transition-colors flex items-center gap-1">
                        <span class="material-symbols-outlined text-sm">logout</span> Đăng xuất
                    </button>
                </form>
            </div>
        </header>
        <main class="p-8">
            @RenderBody()
        </main>
    </div>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
