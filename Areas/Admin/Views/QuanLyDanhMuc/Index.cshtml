@model X.PagedList.IPagedList<ShopLaptop_v1.Models.Category>
@{
    ViewData["Title"] = "Quản lý danh mục / Hãng";
}

@if (TempData["ThanhCong"] != null)
{
    <div class="bg-green-900/20 border border-green-900/40 rounded-lg p-4 mb-6  text-sm text-green-400 flex items-center gap-2">
        <span class="material-symbols-outlined text-sm">check_circle</span>
        @TempData["ThanhCong"]
    </div>
}

@if (TempData["LoiThaoTac"] != null)
{
    <div class="bg-red-900/20 border border-red-900/40 rounded-lg p-4 mb-6  text-sm text-red-400 flex items-center gap-2">
        <span class="material-symbols-outlined text-sm">error</span>
        @TempData["LoiThaoTac"]
    </div>
}

<div class="flex items-center justify-between mb-6">
    <p class=" text-sm text-gray-500">Hiển thị @Model.Count danh mục</p>
    <a asp-action="Tao"
       class="bg-accent-cyber-lime text-black font-['Space_Grotesk'] font-bold text-sm px-5 py-2.5 rounded-lg hover:opacity-90 transition-all flex items-center gap-2">
        <span class="material-symbols-outlined text-sm">add</span> Thêm danh mục
    </a>
</div>

<div class="bg-[#0D0D0D] border border-[#1A1A1A] rounded-xl overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full">
            <thead>
                <tr class="border-b border-[#1A1A1A]">
                    <th class="text-left px-6 py-3  text-[10px] uppercase tracking-widest text-gray-500 w-16">ID</th>
                    <th class="text-left px-6 py-3  text-[10px] uppercase tracking-widest text-gray-500">Tên Hãng</th>
                    <th class="text-left px-6 py-3  text-[10px] uppercase tracking-widest text-gray-500">Mô tả</th>
                    <th class="text-left px-6 py-3  text-[10px] uppercase tracking-widest text-gray-500">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var dm in Model)
                {
                    <tr class="border-b border-[#1A1A1A] hover:bg-[#111] transition-colors">
                        <td class="px-6 py-4  text-sm text-gray-400">#@dm.Id</td>
                        <td class="px-6 py-4">
                            <div class="flex items-center gap-3">
                                <div class="w-10 h-10 bg-white/5 rounded-lg flex-shrink-0 flex items-center justify-center overflow-hidden p-1 border border-[#252525]">
                                    @if (!string.IsNullOrEmpty(dm.ImageUrl))
                                    {
                                        <img src="@dm.ImageUrl" alt="@dm.Name" class="w-full h-full object-contain" />
                                    }
                                    else
                                    {
                                        <span class="material-symbols-outlined text-gray-500">category</span>
                                    }
                                </div>
                                <div>
                                    <p class=" text-sm text-white font-medium">@dm.Name</p>
                                    <p class=" text-xs text-accent-cyber-lime">@dm.Slug</p>
                                </div>
                            </div>
                        </td>
                        <td class="px-6 py-4  text-sm text-gray-400 line-clamp-2 max-w-xs">@dm.Description</td>
                        <td class="px-6 py-4">
                            <div class="flex items-center gap-2">
                                <a asp-action="Sua" asp-route-id="@dm.Id"
                                   class=" text-xs text-blue-400 hover:text-blue-300 border border-blue-900/40 hover:border-blue-900/60 px-3 py-1.5 rounded-lg transition-all flex items-center gap-1">
                                    <span class="material-symbols-outlined text-xs">edit</span> Sửa
                                </a>
                                <form asp-action="Xoa" asp-route-id="@dm.Id" method="post"
                                      onsubmit="return confirm('Xác nhận xóa danh mục này?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit"
                                            class=" text-xs text-red-400 hover:text-red-300 border border-red-900/40 hover:border-red-900/60 px-3 py-1.5 rounded-lg transition-all flex items-center gap-1">
                                        <span class="material-symbols-outlined text-xs">delete</span> Xóa
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Phân trang Admin -->
@if (Model.PageCount > 1)
{
    <div class="mt-8 flex justify-end items-center gap-2">
        @if (Model.HasPreviousPage)
        {
            <a href="@Url.Action("Index", new { page = Model.PageNumber - 1 })"
               class="w-8 h-8 flex items-center justify-center rounded border border-[#252525] bg-[#111] text-white hover:border-accent-cyber-lime hover:text-accent-cyber-lime transition-colors">
                <span class="material-symbols-outlined text-sm">chevron_left</span>
            </a>
        }

        @for (int i = 1; i <= Model.PageCount; i++)
        {
            <a href="@Url.Action("Index", new { page = i })"
               class="w-8 h-8 flex items-center justify-center rounded border @(i == Model.PageNumber ? "border-accent-cyber-lime bg-accent-cyber-lime/10 text-accent-cyber-lime font-bold" : "border-[#252525] bg-[#111] text-gray-400 hover:border-accent-cyber-lime/50 hover:text-white") transition-colors font-['Space_Grotesk'] text-xs">
                @i
            </a>
        }

        @if (Model.HasNextPage)
        {
            <a href="@Url.Action("Index", new { page = Model.PageNumber + 1 })"
               class="w-8 h-8 flex items-center justify-center rounded border border-[#252525] bg-[#111] text-white hover:border-accent-cyber-lime hover:text-accent-cyber-lime transition-colors">
                <span class="material-symbols-outlined text-sm">chevron_right</span>
            </a>
        }
    </div>
}
