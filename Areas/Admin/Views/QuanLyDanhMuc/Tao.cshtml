@{
    ViewData["Title"] = "Thêm danh mục mới";
}

<div class="max-w-2xl">
    @if (TempData["LoiThaoTac"] != null)
    {
        <div class="bg-red-900/20 border border-red-900/40 rounded-lg p-4 mb-6  text-sm text-red-400">@TempData["LoiThaoTac"]</div>
    }

    <form asp-action="Tao" method="post" class="space-y-6">
        @Html.AntiForgeryToken()
        
        <div class="bg-[#0D0D0D] border border-[#1A1A1A] rounded-xl p-6">
            <h2 class="font-['Space_Grotesk'] font-semibold text-white mb-5">Thông tin danh mục</h2>
            <div class="space-y-4">
                <div>
                    <label class=" text-xs text-gray-400 uppercase tracking-widest block mb-2">Tên danh mục / Hãng *</label>
                    <input name="tenDanhMuc" type="text" required
                           class="w-full bg-[#111] border border-[#252525] rounded-lg px-4 py-3 text-white  text-sm focus:outline-none focus:border-accent-cyber-lime transition-all"
                           placeholder="Ví dụ: Asus, Dell, MacBook..." />
                </div>
                
                <div>
                    <label class=" text-xs text-gray-400 uppercase tracking-widest block mb-2">Mô tả ngắn</label>
                    <textarea name="moTa" rows="3"
                              class="w-full bg-[#111] border border-[#252525] rounded-lg px-4 py-3 text-white  text-sm focus:outline-none focus:border-accent-cyber-lime transition-all resize-none"
                              placeholder="Mô tả về hãng laptop này..."></textarea>
                </div>
                
                <div>
                    <label class=" text-xs text-gray-400 uppercase tracking-widest block mb-2">URL Logo hãng</label>
                    <input name="hinhAnh" type="url"
                           class="w-full bg-[#111] border border-[#252525] rounded-lg px-4 py-3 text-white  text-sm focus:outline-none focus:border-accent-cyber-lime transition-all"
                           placeholder="https://..." />
                </div>
            </div>
        </div>

        <div class="flex items-center gap-4">
            <button type="submit"
                    class="bg-accent-cyber-lime text-black font-['Space_Grotesk'] font-bold px-8 py-3 rounded-lg hover:opacity-90 transition-all flex items-center gap-2">
                <span class="material-symbols-outlined text-sm">add_circle</span> THÊM DANH MỤC
            </button>
            <a asp-action="Index" class=" text-sm text-gray-500 hover:text-white transition-colors">Hủy</a>
        </div>
    </form>
</div>
