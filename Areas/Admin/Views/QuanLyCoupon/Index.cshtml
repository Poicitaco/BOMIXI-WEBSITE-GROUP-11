@model List<ShopLaptop_v1.Models.Coupon>
@{
    ViewData["Title"] = "Quan ly coupon";
}

<div class="flex justify-between items-end mb-6">
    <div>
        <h1 class="font-['Space_Grotesk'] text-3xl font-black">Coupon</h1>
        <p class="text-gray-500 text-sm">Tao va kiem soat ma giam gia tai checkout</p>
    </div>
    <a asp-action="Tao" class="bg-accent-cyber-lime text-black px-5 py-3 rounded-lg text-xs font-bold">Tao coupon</a>
</div>

<div class="bg-[#0D0D0D] border border-[#1A1A1A] rounded-xl overflow-x-auto">
    <table class="w-full text-sm">
        <thead><tr class="border-b border-[#252525] text-gray-500 text-left">
            <th class="p-4">Ma</th><th class="p-4">Gia tri</th><th class="p-4">Hieu luc</th>
            <th class="p-4">Da dung</th><th class="p-4">Trang thai</th><th class="p-4">Thao tac</th>
        </tr></thead>
        <tbody>
        @foreach (var coupon in Model)
        {
            <tr class="border-b border-[#1A1A1A]">
                <td class="p-4"><p class="text-accent-cyber-lime font-black">@coupon.Code</p><p class="text-gray-500 text-xs">@coupon.Name</p></td>
                <td class="p-4 text-white">@(coupon.DiscountType == "Fixed" ? coupon.DiscountValue.ToString("N0") + " VND" : coupon.DiscountValue + "%")</td>
                <td class="p-4 text-gray-400 text-xs">@coupon.StartDate.ToString("dd/MM/yyyy") - @coupon.EndDate.ToString("dd/MM/yyyy")</td>
                <td class="p-4 text-white">@coupon.UsedCount / @(coupon.UsageLimit == 0 ? "Khong gioi han" : coupon.UsageLimit)</td>
                <td class="p-4"><span class="@(coupon.IsActive ? "text-green-400" : "text-red-400")">@(coupon.IsActive ? "Dang bat" : "Da tat")</span></td>
                <td class="p-4 flex gap-2">
                    <a asp-action="Sua" asp-route-id="@coupon.Id" class="border border-[#333] px-3 py-2 rounded-lg text-xs">Sua</a>
                    <button onclick="toggleCoupon(@coupon.Id)" class="border border-[#333] px-3 py-2 rounded-lg text-xs">Bat/tat</button>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>

@section Scripts {
<script>
async function toggleCoupon(id) {
    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
    const res = await fetch('/Admin/QuanLyCoupon/DoiTrangThai', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'RequestVerificationToken': token },
        body: `id=${id}`
    });
    const data = await res.json();
    if (data.success) location.reload(); else alert(data.message);
}
</script>
}
