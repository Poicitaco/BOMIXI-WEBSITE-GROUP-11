@{
    ViewData["Title"] = "Trung tâm Chỉ huy";
    var tongSanPham = (int)(ViewData["TongSanPham"] ?? 0);
    var tongDonHang = (int)(ViewData["TongDonHang"] ?? 0);
    var tongDoanhThu = (decimal)(ViewData["TongDoanhThu"] ?? 0m);
    var donChoXacNhan = (int)(ViewData["DonChoXacNhan"] ?? 0);
    var donHangGanNhat = ViewData["DonHangGanNhat"] as List<ShopLaptop_v1.Models.Order>;
    var sapHetHang = ViewData["SapHetHang"] as List<ShopLaptop_v1.Models.ProductVariant>;
    string FormatTien(decimal so) => so.ToString("N0") + " VNĐ";
    string MauTrangThai(string s) => s switch {
        "ChoXacNhan" => "text-yellow-400 bg-yellow-500/10 border border-yellow-500/30 shadow-[0_0_10px_rgba(234,179,8,0.2)]",
        "DangXuLy"   => "text-blue-400 bg-blue-500/10 border border-blue-500/30 shadow-[0_0_10px_rgba(59,130,246,0.2)]",
        "DangGiao"   => "text-purple-400 bg-purple-500/10 border border-purple-500/30 shadow-[0_0_10px_rgba(168,85,247,0.2)]",
        "HoanThanh"  => "text-[#00FF66] bg-[#00FF66]/10 border border-[#00FF66]/30 shadow-[0_0_10px_rgba(0,255,102,0.2)]",
        "DaHuy"      => "text-red-500 bg-red-500/10 border border-red-500/30 shadow-[0_0_10px_rgba(239,68,68,0.2)]",
        _ => "text-gray-400 bg-[#222] border border-[#333]"
    };
    string TenTrangThai(string s) => s switch {
        "ChoXacNhan" => "Chờ duyệt", "DangXuLy" => "Đang xử lý",
        "DangGiao" => "Đang giao", "HoanThanh" => "Hoàn tất", "DaHuy" => "Đã hủy", _ => s
    };
}

<style>
.space-card {
    background: #0D0D0D;
    border: 1px solid #1A1A1A;
    border-radius: 1.5rem;
    position: relative;
    overflow: hidden;
    transition: all 0.3s ease;
}
.space-card::after {
    content: ''; position: absolute; inset: 0;
    background: radial-gradient(circle at top right, rgba(0,255,102,0.05), transparent 70%);
    pointer-events: none;
}
.space-card:hover {
    border-color: rgba(0,255,102,0.4);
    box-shadow: 0 0 30px rgba(0,255,102,0.1), inset 0 0 20px rgba(0,255,102,0.05);
    transform: translateY(-2px);
}
.progress-bar-glow {
    position: relative; overflow: hidden;
}
.progress-bar-glow::after {
    content: ''; position: absolute; top: 0; left: 0; bottom: 0; width: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.4), transparent);
    animation: scanGlow 2s infinite linear;
}
@@keyframes scanGlow {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(100%); }
}
.cyber-grid-bg {
    background-size: 40px 40px;
    background-image: 
        linear-gradient(to right, rgba(0,255,102,0.03) 1px, transparent 1px),
        linear-gradient(to bottom, rgba(0,255,102,0.03) 1px, transparent 1px);
}
</style>

<div class="relative min-h-[80vh] cyber-grid-bg -m-8 p-8 md:p-12 overflow-hidden">
    <!-- Hiệu ứng trạm vũ trụ -->
    <div class="absolute top-[-20%] right-[-10%] w-[800px] h-[800px] bg-[#00FF66] opacity-[0.02] blur-[150px] rounded-full pointer-events-none z-0"></div>
    <div class="absolute bottom-[-20%] left-[-10%] w-[600px] h-[600px] bg-[#00E5FF] opacity-[0.02] blur-[150px] rounded-full pointer-events-none z-0"></div>

    <div class="relative z-10">
        <!-- Header -->
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12">
            <div>
                <h1 class="font-['Space_Grotesk'] text-4xl font-black text-white italic tracking-tighter drop-shadow-[0_0_15px_rgba(0,255,102,0.2)]">TRẠM ĐIỀU KHIỂN</h1>
                <p class="text-[10px] text-[#00FF66] tracking-[0.3em] font-bold uppercase mt-2 flex items-center gap-2">
                    <span class="w-2 h-2 bg-[#00FF66] rounded-full animate-ping"></span> Real-time Telemetry Active
                </p>
            </div>
            <div class="flex gap-4">
                <div class="bg-[#111] border border-[#222] rounded-xl px-4 py-2 flex items-center gap-3">
                    <span class="material-symbols-outlined text-gray-500 text-sm">public</span>
                    <span class="text-xs text-white font-['Space_Grotesk'] font-bold">Trạng thái mạng: <span class="text-[#00FF66]">ỔN ĐỊNH</span></span>
                </div>
            </div>
        </div>

        <!-- Thống kê Core -->
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 mb-10">
            <div class="space-card p-6 border-t-2 border-t-[#00FF66]">
                <div class="flex justify-between items-start mb-4">
                    <div class="w-12 h-12 bg-[#00FF66]/10 border border-[#00FF66]/20 rounded-xl flex items-center justify-center">
                        <span class="material-symbols-outlined text-[#00FF66]">monitoring</span>
                    </div>
                    <span class="font-['Space_Grotesk'] text-[10px] text-gray-400 uppercase tracking-widest font-bold">Tháng này</span>
                </div>
                <div class="font-['Space_Grotesk'] text-3xl font-black text-white drop-shadow-[0_0_10px_rgba(0,255,102,0.3)]">@FormatTien((decimal)(ViewData["DoanhThuThangNay"] ?? 0m))</div>
                <div class="mt-4 flex items-center gap-2 text-xs">
                    <span class="text-[#00FF66] flex items-center"><span class="material-symbols-outlined text-[14px]">trending_up</span>+12%</span>
                    <span class="text-gray-600">vs Tháng trước</span>
                </div>
            </div>
            
            <div class="space-card p-6 border-t-2 border-t-[#00E5FF]">
                <div class="flex justify-between items-start mb-4">
                    <div class="w-12 h-12 bg-[#00E5FF]/10 border border-[#00E5FF]/20 rounded-xl flex items-center justify-center">
                        <span class="material-symbols-outlined text-[#00E5FF]">inventory_2</span>
                    </div>
                    <span class="font-['Space_Grotesk'] text-[10px] text-gray-400 uppercase tracking-widest font-bold">Vũ khí (SP)</span>
                </div>
                <div class="font-['Space_Grotesk'] text-4xl font-black text-white">@tongSanPham</div>
                <div class="mt-4 w-full bg-[#222] h-1.5 rounded-full overflow-hidden">
                    <div class="bg-[#00E5FF] h-full w-[80%] progress-bar-glow"></div>
                </div>
            </div>

            <div class="space-card p-6 border-t-2 border-t-[#FF00FF]">
                <div class="flex justify-between items-start mb-4">
                    <div class="w-12 h-12 bg-[#FF00FF]/10 border border-[#FF00FF]/20 rounded-xl flex items-center justify-center">
                        <span class="material-symbols-outlined text-[#FF00FF]">receipt_long</span>
                    </div>
                    <span class="font-['Space_Grotesk'] text-[10px] text-gray-400 uppercase tracking-widest font-bold">Tổng Đơn</span>
                </div>
                <div class="font-['Space_Grotesk'] text-4xl font-black text-white">@tongDonHang</div>
                <div class="mt-4 w-full bg-[#222] h-1.5 rounded-full overflow-hidden">
                    <div class="bg-[#FF00FF] h-full w-[60%] progress-bar-glow"></div>
                </div>
            </div>

            <div class="space-card p-6 border-t-2 border-t-yellow-400 shadow-[0_0_20px_rgba(250,204,21,0.1)]">
                <div class="flex justify-between items-start mb-4">
                    <div class="w-12 h-12 bg-yellow-400/10 border border-yellow-400/20 rounded-xl flex items-center justify-center animate-pulse">
                        <span class="material-symbols-outlined text-yellow-400">warning</span>
                    </div>
                    <span class="font-['Space_Grotesk'] text-[10px] text-gray-400 uppercase tracking-widest font-bold">Chờ Duyệt</span>
                </div>
                <div class="font-['Space_Grotesk'] text-4xl font-black text-yellow-400 drop-shadow-[0_0_10px_rgba(250,204,21,0.4)]">@donChoXacNhan</div>
                <div class="mt-4 flex justify-between text-[10px] uppercase font-bold tracking-widest">
                    <span class="text-gray-500">Mức độ ưu tiên</span>
                    <span class="text-yellow-400">CAO</span>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-10">
            <!-- Biểu đồ Rada Doanh Thu -->
            <div class="lg:col-span-2 space-card p-6 flex flex-col">
                <div class="flex items-center justify-between mb-8 border-b border-[#1A1A1A] pb-4">
                    <h2 class="font-['Space_Grotesk'] font-bold text-white text-sm uppercase tracking-widest flex items-center gap-2">
                        <span class="material-symbols-outlined text-[#00FF66] text-lg">radar</span> Tín hiệu Doanh Thu (7 Ngày)
                    </h2>
                    <span class="px-3 py-1 bg-[#111] border border-[#222] rounded-md text-[10px] text-gray-400 uppercase font-bold tracking-widest">Live Feed</span>
                </div>
                <div class="h-[300px] w-full flex-1 relative">
                    <!-- Overlay Grid cho chart -->
                    <div class="absolute inset-0 pointer-events-none border border-[#1A1A1A] rounded-xl" style="background-image: linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px); background-size: 20px 20px;"></div>
                    <canvas id="spaceChart"></canvas>
                </div>
            </div>

            <!-- Cảnh báo cạn kiệt (Hết hàng) -->
            <div class="space-card flex flex-col overflow-hidden">
                <div class="px-6 py-5 border-b border-[#1A1A1A] bg-[#111]">
                    <h2 class="font-['Space_Grotesk'] font-bold text-white text-sm uppercase tracking-widest flex items-center gap-2">
                        <span class="material-symbols-outlined text-red-500 text-lg">emergency</span> Báo động Đỏ (Tồn kho)
                    </h2>
                </div>
                <div class="p-6 flex-1 space-y-4">
                    @if (sapHetHang != null && sapHetHang.Any())
                    {
                        @foreach (var bt in sapHetHang)
                        {
                            <div class="p-4 bg-[#050505] border border-red-500/30 rounded-xl relative overflow-hidden group">
                                <div class="absolute left-0 top-0 bottom-0 w-1 bg-red-500 group-hover:shadow-[0_0_15px_#EF4444] transition-all"></div>
                                <div class="pl-2">
                                    <p class="text-sm text-white font-bold truncate">@bt.Product?.Name</p>
                                    <p class="text-xs text-gray-500 mt-1 uppercase tracking-wider">@bt.RAM | @bt.Storage</p>
                                    <div class="flex justify-between items-end mt-3">
                                        <span class="text-[10px] text-red-500 font-bold uppercase tracking-widest animate-pulse">Cạn kiệt</span>
                                        <span class="font-['Space_Grotesk'] font-black text-2xl text-red-500">@bt.StockQuantity</span>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="h-full flex flex-col items-center justify-center opacity-30 text-center">
                            <span class="material-symbols-outlined text-5xl mb-3 text-[#00FF66]">verified</span>
                            <p class="text-xs uppercase font-bold tracking-widest text-[#00FF66]">Kho Hàng An Toàn</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Đơn hàng Live Feed -->
        <div class="space-card">
            <div class="flex items-center justify-between px-6 py-5 border-b border-[#1A1A1A] bg-[#111]">
                <h2 class="font-['Space_Grotesk'] font-bold text-white text-sm uppercase tracking-widest flex items-center gap-2">
                    <span class="material-symbols-outlined text-[#00E5FF] text-lg">satellite_alt</span> Luồng Dữ Liệu Đơn Hàng (Live)
                </h2>
                <a asp-area="Admin" asp-controller="QuanLyDonHang" asp-action="Index"
                   class="text-[10px] text-[#00E5FF] uppercase font-bold tracking-[0.2em] hover:text-white transition-colors border border-[#00E5FF]/30 px-4 py-2 rounded-lg hover:bg-[#00E5FF]/10">Mở toàn bộ</a>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead class="bg-[#0A0A0A]">
                        <tr class="border-b border-[#1A1A1A]">
                            <th class="text-left px-6 py-4 text-[10px] uppercase tracking-[0.2em] text-gray-600 font-black">Mã Nhiệm Vụ</th>
                            <th class="text-left px-6 py-4 text-[10px] uppercase tracking-[0.2em] text-gray-600 font-black">Người Gọi</th>
                            <th class="text-left px-6 py-4 text-[10px] uppercase tracking-[0.2em] text-gray-600 font-black">Năng lượng (VNĐ)</th>
                            <th class="text-left px-6 py-4 text-[10px] uppercase tracking-[0.2em] text-gray-600 font-black">Trạng Thái</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (donHangGanNhat != null && donHangGanNhat.Any())
                        {
                            @foreach (var dh in donHangGanNhat)
                            {
                                <tr class="border-b border-[#1A1A1A] hover:bg-[#111] transition-colors group">
                                    <td class="px-6 py-4 font-['Space_Grotesk'] text-sm text-[#00E5FF] font-bold">
                                        <span class="text-gray-600 mr-1">#</span>@dh.Id
                                    </td>
                                    <td class="px-6 py-4 text-sm text-gray-300 font-medium group-hover:text-white transition-colors">@(dh.User?.Email?.Split('@')[0] ?? "GUEST_USER")</td>
                                    <td class="px-6 py-4 font-['Space_Grotesk'] text-sm text-white font-bold">@FormatTien(dh.TotalAmount)</td>
                                    <td class="px-6 py-4">
                                        <div class="inline-flex items-center gap-1.5 px-3 py-1 rounded-md text-[10px] tracking-widest uppercase font-bold @MauTrangThai(dh.Status)">
                                            @if(dh.Status == "ChoXacNhan") { <span class="w-1.5 h-1.5 rounded-full bg-yellow-400 animate-pulse"></span> }
                                            @TenTrangThai(dh.Status)
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="4" class="px-6 py-10 text-center text-gray-600 text-xs font-bold uppercase tracking-widest">Không có dữ liệu truyền đến</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function() {
        const ctx = document.getElementById('spaceChart').getContext('2d');
        const labels = @Html.Raw(Json.Serialize(ViewData["ChartLabels"]));
        const data = @Html.Raw(Json.Serialize(ViewData["ChartData"]));

        // Tạo Gradient phát sáng cực ngầu
        const gradient = ctx.createLinearGradient(0, 0, 0, 300);
        gradient.addColorStop(0, 'rgba(0, 255, 102, 0.5)'); // Neon Green
        gradient.addColorStop(1, 'rgba(0, 255, 102, 0)');

        // Thêm Glow Effect cho chart
        Chart.defaults.font.family = 'Space Grotesk';
        Chart.defaults.color = '#666';

        new Chart(ctx, {
            type: 'line',
            data: {
                labels: labels,
                datasets: [{
                    label: 'Tín hiệu (VNĐ)',
                    data: data,
                    borderColor: '#00FF66',
                    backgroundColor: gradient,
                    borderWidth: 3,
                    fill: true,
                    tension: 0.4, // Đường cong mượt
                    pointRadius: 4,
                    pointBackgroundColor: '#000',
                    pointBorderColor: '#00FF66',
                    pointBorderWidth: 2,
                    pointHoverRadius: 8,
                    pointHoverBackgroundColor: '#00FF66',
                    pointHoverBorderColor: '#fff',
                    pointHoverBorderWidth: 3,
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                layout: {
                    padding: 10
                },
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        backgroundColor: 'rgba(0,0,0,0.8)',
                        titleColor: '#00FF66',
                        bodyColor: '#fff',
                        borderColor: '#00FF66',
                        borderWidth: 1,
                        padding: 12,
                        cornerRadius: 8,
                        displayColors: false,
                        callbacks: {
                            label: function(context) {
                                return new Intl.NumberFormat('vi-VN').format(context.parsed.y) + ' VNĐ';
                            }
                        }
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        grid: { 
                            color: 'rgba(255, 255, 255, 0.03)',
                            drawBorder: false
                        },
                        ticks: {
                            callback: value => new Intl.NumberFormat('vi-VN').format(value/1000000) + 'M'
                        }
                    },
                    x: {
                        grid: { display: false, drawBorder: false }
                    }
                }
            }
        });
    });
</script>
