@model List<ShopLaptop_v1.Models.Banner>
@{
    ViewData["Title"] = "Quản lý Banner";
}
<div class="mb-8 flex items-center justify-between">
    <h1 class="text-2xl font-black text-white font-['Space_Grotesk'] uppercase tracking-tight">Quản lý Banner</h1>
    <a asp-action="Tao" class="inline-flex items-center gap-2 px-5 py-2.5 bg-accent-cyber-lime text-black font-['Space_Grotesk'] font-black text-xs tracking-widest uppercase transition-all hover:bg-white [clip-path:polygon(8px_0,100%_0,100%_calc(100%-8px),calc(100%-8px)_100%,0_100%,0_8px)]">
        <span class="material-symbols-outlined text-sm">add</span> THÊM BANNER
    </a>
</div>

@if (TempData["ThanhCong"] != null)
{
    <div class="mb-6 p-4 bg-green-900/30 border border-green-500/30 rounded-lg text-green-400 font-['Space_Grotesk'] text-sm">@TempData["ThanhCong"]</div>
}

<div class="overflow-hidden border border-[#252525] rounded-xl">
    <table class="w-full">
        <thead>
            <tr class="bg-[#111] border-b border-[#252525]">
                <th class="px-6 py-4 text-left font-['Space_Grotesk'] text-xs font-700 tracking-widest text-gray-400 uppercase">HÌNH ẢNH</th>
                <th class="px-6 py-4 text-left font-['Space_Grotesk'] text-xs font-700 tracking-widest text-gray-400 uppercase">TIÊU ĐỀ</th>
                <th class="px-6 py-4 text-left font-['Space_Grotesk'] text-xs font-700 tracking-widest text-gray-400 uppercase">TAG</th>
                <th class="px-6 py-4 text-center font-['Space_Grotesk'] text-xs font-700 tracking-widest text-gray-400 uppercase">THỨ TỰ</th>
                <th class="px-6 py-4 text-center font-['Space_Grotesk'] text-xs font-700 tracking-widest text-gray-400 uppercase">TRẠNG THÁI</th>
                <th class="px-6 py-4 text-center font-['Space_Grotesk'] text-xs font-700 tracking-widest text-gray-400 uppercase">HÀNH ĐỘNG</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-[#252525]">
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="6" class="px-6 py-12 text-center font-['Space_Grotesk'] text-sm text-gray-500">Chưa có banner nào. Tạo banner đầu tiên!</td>
                </tr>
            }
            @foreach (var banner in Model)
            {
                <tr class="bg-[#0a0a0a] hover:bg-[#111] transition-colors">
                    <td class="px-6 py-4">
                        <div class="w-24 h-14 bg-black rounded overflow-hidden border border-[#252525]">
                            <img src="@banner.DuongDanAnh" alt="@banner.TieuDe" loading="lazy" class="w-full h-full object-cover" onerror="this.style.display='none'" />
                        </div>
                    </td>
                    <td class="px-6 py-4">
                        <div class="font-['Space_Grotesk'] text-sm font-600 text-white">@banner.TieuDe</div>
                        <div class=" text-xs text-gray-500 mt-0.5">@banner.MoTa</div>
                    </td>
                    <td class="px-6 py-4">
                        <span class="px-2 py-1 text-[#00FF66] border border-[#00FF66]/30 font-['Space_Grotesk'] text-[10px] tracking-widest uppercase rounded">@banner.NhanTag</span>
                    </td>
                    <td class="px-6 py-4 text-center font-['Space_Grotesk'] text-sm text-gray-400">@banner.ThuTu</td>
                    <td class="px-6 py-4 text-center">
                        <button onclick="doiTrangThai(@banner.Id, this)"
                                class="px-3 py-1.5 font-['Space_Grotesk'] text-[10px] tracking-widest uppercase rounded-full border transition-all @(banner.DangHoatDong ? "border-green-500/40 text-green-400 bg-green-900/20" : "border-gray-600 text-gray-500 bg-[#1a1a1a]")">
                            @(banner.DangHoatDong ? "HOẠT ĐỘNG" : "ẨN")
                        </button>
                    </td>
                    <td class="px-6 py-4">
                        <div class="flex items-center justify-center gap-3">
                            <a asp-action="Sua" asp-route-id="@banner.Id" class="text-gray-400 hover:text-white transition-colors" title="Sửa">
                                <span class="material-symbols-outlined text-lg">edit</span>
                            </a>
                            <form asp-action="Xoa" asp-route-id="@banner.Id" method="post" id="delete-form-@banner.Id">
                                @Html.AntiForgeryToken()
                                <button type="button" onclick="xacNhanXoa(@banner.Id)" class="text-gray-400 hover:text-red-400 transition-colors" title="Xóa">
                                    <span class="material-symbols-outlined text-lg">delete</span>
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
<script>
async function doiTrangThai(id, btn) {
    try {
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
        const res = await fetch(`/Admin/QuanLyBanner/DoiTrangThai/${id}`, {
            method: 'POST', headers: {'RequestVerificationToken': token || ''}
        });
        const data = await res.json();
        if (data.success) {
            btn.className = data.dangHoatDong
                ? 'px-3 py-1.5 font-[\'Space_Grotesk\'] text-[10px] tracking-widest uppercase rounded-full border transition-all border-green-500/40 text-green-400 bg-green-900/20'
                : 'px-3 py-1.5 font-[\'Space_Grotesk\'] text-[10px] tracking-widest uppercase rounded-full border transition-all border-gray-600 text-gray-500 bg-[#1a1a1a]';
            btn.textContent = data.dangHoatDong ? 'HOẠT ĐỘNG' : 'ẨN';
        }
    } catch (e) {
        console.error('Lỗi toggle trạng thái:', e);
    }
}

function xacNhanXoa(id) {
    if (confirm('BOMIXI SYSTEM: Bạn có chắc chắn muốn xóa vĩnh viễn banner này?')) {
        document.getElementById(`delete-form-${id}`).submit();
    }
}
</script>
@Html.AntiForgeryToken()
}
