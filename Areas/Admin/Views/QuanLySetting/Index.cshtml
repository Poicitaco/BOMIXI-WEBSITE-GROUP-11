@model IEnumerable<ShopLaptop_v1.Models.SystemSetting>
@{
    ViewData["Title"] = "Cấu hình hệ thống";
    Layout = "_Layout";
}

<style>
.admin-card {
    background: #0D0D0D;
    border: 1px solid #1a1a1a;
    border-radius: 1.5rem;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    position: relative;
    overflow: hidden;
}
.setting-item {
    background: #111;
    border: 1px solid #222;
    border-radius: 1rem;
    transition: all 0.3s ease;
}
.setting-item:hover {
    border-color: rgba(0,255,102,0.3);
    transform: translateX(4px);
}
.input-admin {
    width: 100%; background-color: #050505; border: 1px solid #333; border-radius: 0.75rem;
    color: #fff; font-size: 0.875rem; font-weight: 500;
    transition: all 0.3s; outline: none; box-shadow: inset 0 2px 4px rgba(0,0,0,0.5);
}
.input-admin:focus { border-color: #00FF66; box-shadow: 0 0 0 1px #00FF66, inset 0 2px 4px rgba(0,0,0,0.5); }
</style>

<div class="admin-card p-8 md:p-10 min-h-[70vh]">
    <!-- Hiệu ứng trang trí -->
    <div class="absolute top-[-100px] right-[-100px] w-96 h-96 bg-[#00FF66] opacity-5 blur-[100px] rounded-full pointer-events-none z-0"></div>
    <div class="absolute bottom-[-100px] left-[-100px] w-96 h-96 bg-[#00FF66] opacity-[0.03] blur-[100px] rounded-full pointer-events-none z-0"></div>
    <div class="absolute top-8 right-10 opacity-5 pointer-events-none z-0">
        <span class="material-symbols-outlined text-[120px]">admin_panel_settings</span>
    </div>

    <div class="relative z-10">
        <div class="flex flex-col md:flex-row md:items-center justify-between mb-12 gap-4 border-b border-[#1a1a1a] pb-6">
            <div class="flex items-center gap-4">
                <div class="w-14 h-14 bg-[#00FF66]/10 border border-[#00FF66]/20 rounded-2xl flex items-center justify-center shadow-[0_0_15px_rgba(0,255,102,0.1)]">
                    <span class="material-symbols-outlined text-[#00FF66] text-3xl">display_settings</span>
                </div>
                <div>
                    <h2 class="font-['Space_Grotesk'] text-3xl font-black text-white uppercase italic tracking-tighter">Cấu Hình Lõi</h2>
                    <p class="text-xs text-gray-500 tracking-widest uppercase mt-1 font-bold">Trung tâm điều khiển BOMIXI</p>
                </div>
            </div>
            <div class="flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-gray-400 bg-[#111] border border-[#222] px-4 py-2 rounded-lg shadow-inner">
                <span class="w-2 h-2 rounded-full bg-[#00FF66] animate-pulse"></span>
                Hệ thống đang hoạt động
            </div>
        </div>

        <div class="space-y-5">
            @foreach (var s in Model)
            {
                <div class="setting-item p-6 flex flex-col lg:flex-row lg:items-center justify-between gap-6 group">
                    <div class="flex-1">
                        <div class="flex items-center gap-3 mb-2">
                            <span class="material-symbols-outlined text-gray-500 group-hover:text-[#00FF66] transition-colors text-lg">data_object</span>
                            <span class="font-['Space_Grotesk'] text-[15px] font-bold text-white uppercase tracking-wider group-hover:text-[#00FF66] transition-colors">@s.Key</span>
                            <span class="px-2.5 py-0.5 bg-[#222] border border-[#333] rounded text-[9px] text-gray-400 font-bold uppercase tracking-widest shadow-sm">SYS_VAR</span>
                        </div>
                        <p class="text-[12px] text-gray-500 pl-8 border-l-2 border-[#222] ml-[9px]">@s.Description</p>
                    </div>

                    <div class="flex-1 max-w-md w-full">
                        @if (s.Key.Contains("IsActive") || s.Key.Contains("Enable") || s.Value == "True" || s.Value == "False")
                        {
                            <div class="relative">
                                <select onchange="updateSetting(@s.Id, this.value)" class="input-admin py-3 px-4 appearance-none cursor-pointer">
                                    <option value="True" selected="@(s.Value == "True")">BẬT (Kích hoạt)</option>
                                    <option value="False" selected="@(s.Value == "False")">TẮT (Vô hiệu hóa)</option>
                                </select>
                                <span class="material-symbols-outlined absolute right-4 top-3.5 text-gray-500 pointer-events-none text-lg">unfold_more</span>
                            </div>
                        }
                        else if (s.Key.Contains("Date") || s.Key.Contains("Time"))
                        {
                            <div class="relative">
                                <span class="material-symbols-outlined absolute left-4 top-3.5 text-gray-500 pointer-events-none text-lg z-10">event</span>
                                <input type="datetime-local" value="@(DateTime.TryParse(s.Value, out var d) ? d.ToString("yyyy-MM-ddTHH:mm") : "")" 
                                       onchange="updateSetting(@s.Id, this.value.replace('T', ' '))"
                                       class="input-admin py-3 pr-4 pl-12 relative" />
                            </div>
                        }
                        else
                        {
                            <div class="relative">
                                <span class="material-symbols-outlined absolute left-4 top-3.5 text-gray-500 pointer-events-none text-lg z-10">edit_note</span>
                                <input type="text" value="@s.Value" onblur="updateSetting(@s.Id, this.value)"
                                       class="input-admin py-3 pr-4 pl-12 relative" placeholder="Nhập giá trị..." />
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function updateSetting(id, val) {
            fetch('/Admin/QuanLySetting/Update', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `id=${id}&value=${encodeURIComponent(val)}`
            }).then(res => res.json()).then(data => {
                if(data.success) {
                    if (typeof showToast === "function") {
                        showToast('Đã lưu cấu hình hệ thống!', 'success');
                    } else {
                        // Fallback in case toast isn't available in Admin layout
                        const x = document.createElement('div');
                        x.innerHTML = `<div style="position:fixed;bottom:20px;right:20px;background:#00FF66;color:#000;padding:10px 20px;border-radius:8px;font-weight:bold;z-index:9999;box-shadow:0 10px 25px rgba(0,255,102,0.3);">Đã lưu thành công!</div>`;
                        document.body.appendChild(x);
                        setTimeout(() => x.remove(), 3000);
                    }
                }
            }).catch(err => {
                console.error(err);
                if (typeof showToast === "function") showToast('Lỗi cập nhật cấu hình', 'error');
            });
        }
    </script>
}
