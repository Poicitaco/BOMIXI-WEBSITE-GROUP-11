@model X.PagedList.IPagedList<ShopLaptop_v1.Models.Product>
@{
    ViewData["Title"] = "Quản lý sản phẩm";
}

@if (TempData["ThanhCong"] != null)
{
    <div class="bg-green-900/20 border border-green-900/40 rounded-lg p-4 mb-6  text-sm text-green-400 flex items-center gap-2">
        <span class="material-symbols-outlined text-sm">check_circle</span>
        @TempData["ThanhCong"]
    </div>
}

@if (TempData["LoiThaoTac"] != null)
{
    <div class="bg-red-900/20 border border-red-900/40 rounded-lg p-4 mb-6 text-sm text-red-400">
        @TempData["LoiThaoTac"]
    </div>
}

<div class="flex items-center justify-between mb-6">
    <p class=" text-sm text-gray-500">@Model.Count sản phẩm trong kho</p>
    <a asp-action="Tao"
       class="bg-accent-cyber-lime text-black font-['Space_Grotesk'] font-bold text-sm px-5 py-2.5 rounded-lg hover:opacity-90 transition-all flex items-center gap-2">
        <span class="material-symbols-outlined text-sm">add</span> Thêm sản phẩm
    </a>
</div>

<div class="bg-[#0D0D0D] border border-[#1A1A1A] rounded-xl overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full">
            <thead>
                <tr class="border-b border-[#1A1A1A]">
                    <th class="text-left px-6 py-3  text-[10px] uppercase tracking-widest text-gray-500">Sản phẩm</th>
                    <th class="text-left px-6 py-3  text-[10px] uppercase tracking-widest text-gray-500">Hãng</th>
                    <th class="text-left px-6 py-3  text-[10px] uppercase tracking-widest text-gray-500">Cấu hình</th>
                    <th class="text-left px-6 py-3  text-[10px] uppercase tracking-widest text-gray-500">Giá</th>
                    <th class="text-left px-6 py-3  text-[10px] uppercase tracking-widest text-gray-500">Tồn kho</th>
                    <th class="text-left px-6 py-3  text-[10px] uppercase tracking-widest text-gray-500">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var sp in Model)
                {
                    var bienThe = sp.Variants.FirstOrDefault();
                    var hinhAnh = sp.Images.FirstOrDefault(i => i.IsMainImage)?.ImageUrl ?? sp.Images.FirstOrDefault()?.ImageUrl;
                    <tr class="border-b border-[#1A1A1A] hover:bg-[#111] transition-colors">
                        <td class="px-6 py-4">
                            <div class="flex items-center gap-3">
                                <div class="w-12 h-10 bg-black rounded-lg flex-shrink-0 flex items-center justify-center overflow-hidden p-1 border border-[#1A1A1A]">
                                    @if (!string.IsNullOrEmpty(hinhAnh))
                                    {
                                        <img src="@hinhAnh" alt="@sp.Name" class="w-full h-full object-contain" />
                                    }
                                    else
                                    {
                                        <span class="material-symbols-outlined text-[#333]">laptop</span>
                                    }
                                </div>
                                <div>
                                    <p class=" text-sm text-white font-medium">@sp.Name</p>
                                    <p class=" text-xs text-gray-600">#@sp.Id</p>
                                </div>
                            </div>
                        </td>
                        <td class="px-6 py-4  text-sm text-accent-cyber-lime">@sp.Category?.Name</td>
                        <td class="px-6 py-4">
                            @if (bienThe != null)
                            {
                                <p class=" text-xs text-gray-400">@bienThe.CPU</p>
                                <p class=" text-xs text-gray-500">@bienThe.RAM · @bienThe.Storage</p>
                            }
                        </td>
                        <td class="px-6 py-4">
                            @if (bienThe != null)
                            {
                                <p class="font-['Space_Grotesk'] text-sm text-white font-bold">@(bienThe.DiscountPrice?.ToString("N0") ?? bienThe.Price.ToString("N0")) VNĐ</p>
                                @if (bienThe.DiscountPrice.HasValue)
                                {
                                    <p class=" text-xs text-gray-500 line-through">@bienThe.Price.ToString("N0") VNĐ</p>
                                }
                            }
                        </td>
                        <td class="px-6 py-4">
                            @if (bienThe != null)
                            {
                                <span class="font-['Space_Grotesk'] font-bold text-sm @(bienThe.StockQuantity == 0 ? "text-red-400" : bienThe.StockQuantity <= 5 ? "text-yellow-400" : "text-green-400")">
                                    @bienThe.StockQuantity
                                </span>
                            }
                        </td>
                        <td class="px-6 py-4">
                            <div class="flex items-center gap-2">
                                <a href="/Home/ChiTiet/@sp.Id" target="_blank"
                                   class=" text-xs text-gray-500 hover:text-white border border-[#252525] hover:border-[#333] px-3 py-1.5 rounded-lg transition-all flex items-center gap-1">
                                    <span class="material-symbols-outlined text-xs">visibility</span> Xem
                                </a>
                                <a asp-action="Sua" asp-route-id="@sp.Id"
                                   class=" text-xs text-blue-400 hover:text-blue-300 border border-blue-900/40 hover:border-blue-900/60 px-3 py-1.5 rounded-lg transition-all flex items-center gap-1">
                                    <span class="material-symbols-outlined text-xs">edit</span> Sửa
                                </a>
                                <form asp-action="Xoa" asp-route-id="@sp.Id" method="post"
                                      onsubmit="return confirm('Xác nhận xóa sản phẩm này?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit"
                                            class=" text-xs text-red-400 hover:text-red-300 border border-red-900/40 hover:border-red-900/60 px-3 py-1.5 rounded-lg transition-all flex items-center gap-1">
                                        <span class="material-symbols-outlined text-xs">delete</span> Xóa
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Phân trang Admin -->
@if (Model.PageCount > 1)
{
    <div class="mt-8 flex justify-end items-center gap-2">
        @if (Model.HasPreviousPage)
        {
            <a href="@Url.Action("Index", new { page = Model.PageNumber - 1 })"
               class="w-8 h-8 flex items-center justify-center rounded border border-[#252525] bg-[#111] text-white hover:border-accent-cyber-lime hover:text-accent-cyber-lime transition-colors">
                <span class="material-symbols-outlined text-sm">chevron_left</span>
            </a>
        }

        @for (int i = 1; i <= Model.PageCount; i++)
        {
            <a href="@Url.Action("Index", new { page = i })"
               class="w-8 h-8 flex items-center justify-center rounded border @(i == Model.PageNumber ? "border-accent-cyber-lime bg-accent-cyber-lime/10 text-accent-cyber-lime font-bold" : "border-[#252525] bg-[#111] text-gray-400 hover:border-accent-cyber-lime/50 hover:text-white") transition-colors font-['Space_Grotesk'] text-xs">
                @i
            </a>
        }

        @if (Model.HasNextPage)
        {
            <a href="@Url.Action("Index", new { page = Model.PageNumber + 1 })"
               class="w-8 h-8 flex items-center justify-center rounded border border-[#252525] bg-[#111] text-white hover:border-accent-cyber-lime hover:text-accent-cyber-lime transition-colors">
                <span class="material-symbols-outlined text-sm">chevron_right</span>
            </a>
        }
    </div>
}
